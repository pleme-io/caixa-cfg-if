   :body "#![allow(unexpected_cfgs)] // `foo` doesn't exist\n\ncfg_if::cfg_if! {\n    if #[cfg(foo)] {\n        fn works() -> bool { false }\n    } else if #[cfg(test)] {\n        fn works() -> bool { true }\n    } else {\n        fn works() -> bool { false }\n    }\n}\n\n#[test]\nfn smoke() {\n    assert!(works());\n}\n"} {:path "README.md"
